{
  "expo": {
    "name": "Dwar - Rental Management",
    "slug": "dwar-rental",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dwar",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "extra": {
      "supabaseUrl": "https://ixifovzqctqummuzxtnm.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml4aWZvdnpxY3RxdW1tdXp4dG5tIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMxNjM0NDUsImV4cCI6MjA5ODczOTQ0NX0.LWFZWMUizGXijQ7soXSyzDH5TvWN__GID-U7UNarltY",
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dwar.dawar",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload payment receipts and property photos",
        "NSCameraUsageDescription": "Capture payment receipts instantly",
        "NSPhotoLibraryAddUsageDescription": "Save property and receipt images"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F7F8F4"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.dwar.dwar",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7F8F4"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0E5C4C",
          "sounds": ["./assets/sounds/notification.wav"]
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}